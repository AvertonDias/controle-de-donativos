
{
  "entities": {
    "DonationEntry": {
      "title": "Registro de Donativo",
      "description": "Um lançamento diário de contribuições para a obra mundial e congregação.",
      "type": "object",
      "properties": {
        "date": {
          "type": "string",
          "format": "date",
          "description": "Data do lançamento"
        },
        "worldwideWork": {
          "type": "number",
          "description": "Valor para a Obra Mundial"
        },
        "congregation": {
          "type": "number",
          "description": "Valor para a Congregação"
        },
        "dailySum": {
          "type": "number",
          "description": "Soma total do dia"
        },
        "observations": {
          "type": "string",
          "description": "Observações ou justificativas para o registro"
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "Data de criação do registro (Timestamp)"
        }
      },
      "required": [
        "date",
        "worldwideWork",
        "congregation",
        "dailySum"
      ]
    },
    "UserSettings": {
      "title": "Configurações do Usuário",
      "description": "Configurações personalizadas do sistema para o usuário.",
      "type": "object",
      "properties": {
        "meetingDays": {
          "type": "array",
          "items": {
            "type": "number"
          },
          "description": "Dias da semana com reunião (0=Domingo, 1=Segunda, etc.)"
        }
      }
    }
  },
  "auth": {
    "providers": [
      "google.com",
      "password"
    ]
  },
  "firestore": {
    "/users/{userId}/donations/{yearId}/months/{monthId}/entries/{donationId}": {
      "schema": "DonationEntry",
      "description": "Registros de donativos exclusivos e privados de cada usuário."
    },
    "/users/{userId}/settings/general": {
      "schema": "UserSettings",
      "description": "Configurações gerais do usuário."
    }
  }
}
